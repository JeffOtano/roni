# Next.js environment variables
# Copy this file to .env.local and fill in the values.
# Run `npx convex dev` first — it writes CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL automatically.

# Written by `npx convex dev` — do not edit manually
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex deployment URL (written by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# Convex HTTP deployment URL — add this manually after `npx convex dev` runs
# Same deployment name as above, but .convex.site domain
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Public URL of the GitHub repository. Set this once the repo is public.
# The OpenSourceBanner only shows when this is set.
NEXT_PUBLIC_GITHUB_REPO_URL=

# ---------------------------------------------------------------------------
# Convex backend secrets — set these via `npx convex env set KEY value`
# They are NOT read from .env.local at runtime; this block is for reference only.
# ---------------------------------------------------------------------------

# Google AI Studio API key (https://aistudio.google.com)
# Used for Gemini 2.5 Pro (AI coach)
# npx convex env set GOOGLE_GENERATIVE_AI_API_KEY your-key

# Resend API key (https://resend.com) — used for password-reset OTP emails
# npx convex env set AUTH_RESEND_KEY re_your_key

# 64-char hex string (32 bytes) for encrypting Tonal OAuth tokens at rest
# Generate: openssl rand -hex 32
# npx convex env set TOKEN_ENCRYPTION_KEY your-64-char-hex

# Public app URL — used for OAuth redirects
# npx convex env set APP_URL http://localhost:3000
